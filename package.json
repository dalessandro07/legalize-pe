{
  "name": "legalize-pe",
  "version": "0.0.1",
  "private": true,
  "description": "Legislación peruana como repositorio Git",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,astro}": ["biome check --write"],
    "*.{json,md}": ["biome format --write"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": ["apps/*", "packages/*"]
}
