---
export const prerender = true

import { readFileSync, readdirSync, statSync } from 'node:fs'
import { join, relative } from 'node:path'
import Layout from '../layouts/Layout.astro'

interface LeyCard {
  titulo: string
  identificador: string
  rango: string
  estado: string
  fechaPublicacion?: string
}

function parseLeyCard(content: string): LeyCard {
  const parts = content.split(/^---\s*$/m)
  const yamlBlock = parts[1] ?? ''
  const result: Record<string, string> = {}
  for (const line of yamlBlock.split('\n')) {
    const match = line.match(/^(\w+):\s*"?([^"]*?)"?\s*$/)
    if (match) result[match[1]] = match[2].trim()
  }
  return result as unknown as LeyCard
}

function getAllMdFiles(dir: string, baseDir: string = dir): string[] {
  const files: string[] = []
  for (const entry of readdirSync(dir)) {
    if (entry.startsWith('.') || entry.startsWith('HISTORIAL')) continue
    const fullPath = join(dir, entry)
    const stat = statSync(fullPath)
    if (stat.isDirectory()) {
      files.push(...getAllMdFiles(fullPath, baseDir))
    } else if (entry.endsWith('.md')) {
      files.push(fullPath)
    }
  }
  return files
}

const leyesDir = join(process.cwd(), '../../leyes/pe')
const leyFiles = getAllMdFiles(leyesDir)
const leyes = leyFiles
  .map((f) => parseLeyCard(readFileSync(f, 'utf-8')))
  .filter((ley) => ley.titulo && ley.identificador)
  .sort((a, b) =>
    (b.fechaPublicacion ?? '').localeCompare(a.fechaPublicacion ?? ''),
  )

const rangoLabels: Record<string, string> = {
  constitucion: 'Constitución',
  ley: 'Ley',
  'ley-organica': 'Ley Orgánica',
  'decreto-legislativo': 'D. Leg.',
  'decreto-urgencia': 'D. Urg.',
  'decreto-supremo': 'D. Sup.',
  'resolucion-suprema': 'R. Sup.',
  'resolucion-ministerial': 'R. Min.',
  'resolucion-jefatural': 'R. Jef.',
  'resolucion-directoral': 'R. Dir.',
  resolucion: 'Resolución',
  ordenanza: 'Ordenanza',
  reglamento: 'Reglamento',
}

// Categorías populares
const categorias = [
  { label: 'Constitución', query: 'constitucion' },
  { label: 'Código Civil', query: 'codigo+civil' },
  { label: 'Código Penal', query: 'codigo+penal' },
  { label: 'Laboral', query: 'laboral' },
  { label: 'Tributario', query: 'tributario' },
  { label: 'Comercio', query: 'comercio' },
]
---

<Layout title="Legalize PE — Legislación Peruana">
  <main id="main-content">
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <h1>Legislación Peruana</h1>
        <p class="tagline">
          Busca y consulta leyes, decretos y resoluciones del Perú.
        </p>

        <form class="search-form" action="/leyes" method="get" role="search">
          <div class="search-wrap">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <input
              type="search"
              name="q"
              placeholder="Buscar por título, número o tema…"
              class="search-input"
              autocomplete="off"
              aria-label="Buscar normas"
            />
            <button type="submit" class="search-btn">Buscar</button>
          </div>
        </form>

        <div class="categorias">
          {categorias.map((cat) => (
            <a href={`/leyes?q=${cat.query}`} class="cat-chip">{cat.label}</a>
          ))}
        </div>

        <div class="smart-search-link">
          <a href="/consulta" class="smart-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            Consulta en lenguaje natural
          </a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats-bar" aria-label="Estadísticas del repositorio">
      <div class="container" role="group" aria-label="Métricas principales">
        <div class="stat">
          <span class="stat-num">{leyes.length.toLocaleString()}</span>
          <span class="stat-label">Normas</span>
        </div>
        <div class="stat">
          <span class="stat-num">Actualizado</span>
          <span class="stat-label">Diariamente</span>
        </div>
        <div class="stat">
          <span class="stat-num">Gratis</span>
          <span class="stat-label">y Open Source</span>
        </div>
      </div>
    </section>

    <!-- Últimas normas -->
    <section class="section">
      <div class="container">
        <h2 class="section-title">Últimas normas publicadas</h2>
        <div class="leyes-grid">
          {leyes.slice(0, 12).map((ley) => (
            <a href={`/leyes/${ley.identificador}`} class="ley-card">
              <div class="ley-meta">
                <span class="badge">{rangoLabels[ley.rango] ?? ley.rango}</span>
                {ley.fechaPublicacion && (
                  <span class="ley-fecha">{ley.fechaPublicacion}</span>
                )}
              </div>
              <span class="ley-titulo">{ley.titulo}</span>
            </a>
          ))}
        </div>
        <div class="section-footer">
          <a href="/leyes" class="btn-secondary">Ver todas las normas</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <div class="cta-text">
            <h2>Para desarrolladores</h2>
            <p>API REST gratuita, repositorio Git con historial de cambios, y documentación completa.</p>
          </div>
          <a href="/developers" class="btn-primary">Ver documentación</a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="container footer-content">
        <div class="footer-brand">
          <strong>Legalize PE</strong>
          <span>por <a href="https://shiara.design" target="_blank" rel="noopener">Shiara Arauzo<span class="sr-only"> (abre en nueva ventana)</span></a></span>
        </div>
        <nav class="footer-links" aria-label="Enlaces del pie de página">
          <a href="/leyes">Normas</a>
          <a href="/consulta">Consulta Legal</a>
          <a href="/developers">Developers</a>
          <a href="https://github.com/crafter-research/legalize-pe" target="_blank" rel="noopener">GitHub<span class="sr-only"> (abre en nueva ventana)</span></a>
          <a href="https://ko-fi.com/shiaradesign" target="_blank" rel="noopener" class="coffee-link">☕ Invítame un café<span class="sr-only"> (abre en nueva ventana)</span></a>
        </nav>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero {
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .hero h1 {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-bottom: 2rem;
  }

  /* Search */
  .search-form {
    max-width: 560px;
    margin: 0 auto 1.5rem;
  }

  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #111;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 0.625rem 0.625rem 0.625rem 1.25rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .search-wrap:focus-within {
    border-color: #555;
    box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
  }

  .search-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-size: 1rem;
    padding: 0.5rem 0;
  }

  .search-input::placeholder {
    color: #8a8a8a;
  }

  .search-btn {
    background: #fff;
    color: #000;
    border: none;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  .search-btn:hover {
    background: #e5e5e5;
  }

  /* Categorías */
  .categorias {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .cat-chip {
    padding: 0.4rem 0.9rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    transition: all 0.15s;
  }

  .cat-chip:hover {
    border-color: #555;
    color: var(--color-text);
    text-decoration: none;
  }

  /* Smart Search Link */
  .smart-search-link {
    margin-top: 1.25rem;
    text-align: center;
  }

  .smart-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
  }

  .smart-link:hover {
    border-color: #555;
    color: var(--color-text);
    text-decoration: none;
  }

  .smart-link svg {
    flex-shrink: 0;
  }

  /* Stats */
  .stats-bar {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem 0;
  }

  .stats-bar .container {
    display: flex;
    justify-content: center;
    gap: 4rem;
  }

  .stat {
    text-align: center;
  }

  .stat-num {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Sections */
  .section {
    padding: 3rem 0;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .section-footer {
    margin-top: 2rem;
    text-align: center;
  }

  /* Laws grid */
  .leyes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
  }

  .ley-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .ley-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .ley-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ley-fecha {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .ley-titulo {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    background: #1a1a1a;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  /* Buttons */
  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: #fff;
    color: #000;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.15s;
  }

  .btn-primary:hover {
    background: #e5e5e5;
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: border-color 0.15s;
  }

  .btn-secondary:hover {
    border-color: #555;
    text-decoration: none;
  }

  /* CTA Section */
  .cta-section {
    padding: 2.5rem 0;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
  }

  .cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .cta-text h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
  }

  .cta-text p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  /* Footer */
  footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.875rem;
  }

  .footer-brand span {
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.875rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-text);
  }

  .coffee-link {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: border-color 0.15s, color 0.15s;
  }

  .coffee-link:hover {
    border-color: #555;
  }

  /* Tablet */
  @media (max-width: 768px) {
    .leyes-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    }

    .footer-links {
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .container {
      padding: 0 1rem;
    }

    .hero {
      padding: 2.5rem 0 2rem;
    }

    .hero h1 {
      font-size: 1.75rem;
    }

    .tagline {
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }

    .search-wrap {
      padding: 0.5rem 0.5rem 0.5rem 1rem;
      gap: 0.5rem;
    }

    .search-input {
      font-size: 0.9rem;
    }

    .search-btn {
      padding: 0.5rem 1rem;
      font-size: 0.85rem;
    }

    .categorias {
      gap: 0.375rem;
    }

    .cat-chip {
      padding: 0.35rem 0.75rem;
      font-size: 0.8rem;
    }

    .stats-bar {
      padding: 1rem 0;
    }

    .stats-bar .container {
      gap: 1.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .stat-num {
      font-size: 1.1rem;
    }

    .stat-label {
      font-size: 0.75rem;
    }

    .section {
      padding: 2rem 0;
    }

    .section-title {
      font-size: 1.1rem;
    }

    .leyes-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .ley-card {
      padding: 0.875rem 1rem;
    }

    .cta-section {
      padding: 2rem 0;
    }

    .cta-content {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .cta-text h2 {
      font-size: 1.1rem;
    }

    .cta-text p {
      font-size: 0.9rem;
    }

    footer {
      padding: 1.5rem 0;
    }

    .footer-content {
      flex-direction: column;
      gap: 1.25rem;
      text-align: center;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-links {
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }

    .coffee-link {
      margin-top: 0.25rem;
    }
  }

  /* Very small screens */
  @media (max-width: 380px) {
    .hero h1 {
      font-size: 1.5rem;
    }

    .search-btn {
      padding: 0.5rem 0.75rem;
    }

    .stats-bar .container {
      gap: 1rem;
    }

    .stat {
      min-width: 80px;
    }
  }
</style>

<script>
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault()
      const input = document.querySelector('.search-input') as HTMLInputElement
      input?.focus()
      input?.select()
    }
  })
</script>
