---
export const prerender = true

import { readFileSync } from 'node:fs'
import { join } from 'node:path'
import { marked } from 'marked'
import Layout from '../../layouts/Layout.astro'
import { buildIdToFileMap, parseFrontmatter, LEYES_DIR, rangoLabels } from '../../lib/leyes'

export async function getStaticPaths() {
  const idToFileMap = buildIdToFileMap(LEYES_DIR)
  return [...idToFileMap.entries()].map(([id, filename]) => ({
    params: { id },
    props: { filename },
  }))
}

const { id } = Astro.params
const { filename } = Astro.props

const rawContent = readFileSync(join(LEYES_DIR, filename), 'utf-8')
const { meta, body } = parseFrontmatter(rawContent)

// Extract headings for TOC
interface TocItem {
  level: number
  text: string
  slug: string
}

function slugify(text: string): string {
  return text
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '') // Remove accents
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
}

function extractHeadings(markdown: string): TocItem[] {
  const headings: TocItem[] = []
  const lines = markdown.split('\n')

  for (const line of lines) {
    const match = line.match(/^(#{2,4})\s+(.+)$/)
    if (match) {
      const level = match[1].length
      const text = match[2].replace(/\*+/g, '').trim()
      if (text.length > 0 && text.length < 150) {
        headings.push({
          level,
          text,
          slug: slugify(text),
        })
      }
    }
  }

  return headings
}

const tocItems = extractHeadings(body)
const hasToc = tocItems.length >= 3

// Configure marked to add IDs and copy link buttons to headings
marked.use({
  renderer: {
    heading({ tokens, depth }) {
      const text = this.parser.parseInline(tokens)
      const rawText = tokens.map(t => t.raw || '').join('')
      const slug = slugify(rawText)
      const linkIcon = `<button class="heading-link" data-slug="${slug}" title="Copiar enlace" aria-label="Copiar enlace a esta seccion"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></button>`
      return `<h${depth} id="${slug}">${text}${linkIcon}</h${depth}>\n`
    }
  }
})

const htmlContent = await marked(body)

// Citation data
const citationData = {
  titulo: meta.titulo,
  identificador: meta.identificador,
  rango: rangoLabels[meta.rango] ?? meta.rango,
  fechaPublicacion: meta.fechaPublicacion,
  diarioOficial: meta.diarioOficial || 'El Peruano',
}

// JSON-LD structured data for SEO
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Legislation",
  "name": meta.titulo,
  "identifier": meta.identificador,
  "legislationType": rangoLabels[meta.rango] ?? meta.rango,
  "datePublished": meta.fechaPublicacion,
  "jurisdiction": {
    "@type": "AdministrativeArea",
    "name": "Peru"
  },
  "inLanguage": "es",
  "url": `https://legalize.crafter.ing/leyes/${id}`,
  "publisher": {
    "@type": "Organization",
    "name": meta.diarioOficial || "El Peruano"
  }
}
---

<Layout title={`${meta.titulo} — Legalize PE`} description={`${meta.titulo}. ${rangoLabels[meta.rango] ?? meta.rango} peruana publicada el ${meta.fechaPublicacion}.`}>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <main id="main-content">
    <div class="container">
      <nav class="breadcrumb" aria-label="Navegación de ruta">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/leyes">Normas</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{id}</span>
      </nav>

      <div class="page-top">
        <div class="page-header">
          <h1>{meta.titulo}</h1>
          <div class="meta-badges">
            <span class="badge badge-rango">
              {rangoLabels[meta.rango] ?? meta.rango}
            </span>
            {meta.estado === 'vigente' && (
              <span class="badge badge-vigente">Vigente</span>
            )}
          </div>
          {meta.ocrQuality === 'poor' && (
            <div class="ocr-warning" role="alert">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
              <div>
                <strong>Calidad de texto limitada</strong>
                <p>Este documento fue procesado con OCR desde un PDF escaneado antiguo. El texto puede contener errores de reconocimiento.</p>
              </div>
            </div>
          )}
          <dl class="meta-grid">
            <div>
              <dt>Publicacion</dt>
              <dd>{meta.fechaPublicacion}</dd>
            </div>
            <div>
              <dt>Ultima actualizacion</dt>
              <dd>{meta.ultimaActualizacion}</dd>
            </div>
            {meta.diarioOficial && (
              <div>
                <dt>Diario Oficial</dt>
                <dd>{meta.diarioOficial}</dd>
              </div>
            )}
            {meta.fuente && (
              <div>
                <dt>Fuente</dt>
                <dd>
                  <a href={meta.fuente} target="_blank" rel="noopener">
                    SPIJ / Minjus<span class="sr-only"> (abre en nueva ventana)</span> &nearr;
                  </a>
                </dd>
              </div>
            )}
          </dl>
        </div>

        <div class="action-buttons">
          <button id="btn-bookmark" class="btn btn-primary" type="button" title="Guardar en favoritos">
            <svg class="icon-bookmark-outline" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
            <svg class="icon-bookmark-filled" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" style="display:none">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
            <span class="btn-text" id="bookmark-text">Guardar</span>
          </button>
          <button id="btn-cite" class="btn btn-secondary" type="button">
            Citar
          </button>
          <button id="btn-print" class="btn btn-secondary" type="button" title="Imprimir / Guardar PDF">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
              <rect x="6" y="14" width="12" height="8"/>
            </svg>
            <span class="btn-text">PDF</span>
          </button>
          <button id="btn-share" class="btn btn-secondary" type="button" title="Compartir">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            <span class="btn-text">Compartir</span>
          </button>
        </div>

        <!-- Share Menu -->
        <div id="share-menu" class="share-menu" hidden>
          <button type="button" class="share-option" data-share="twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            Twitter / X
          </button>
          <button type="button" class="share-option" data-share="linkedin">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </button>
          <button type="button" class="share-option" data-share="whatsapp">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </button>
          <button type="button" class="share-option" data-share="copy">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            Copiar enlace
          </button>
        </div>

        <!-- Citation Modal -->
        <div id="citation-modal" class="modal" hidden>
          <div class="modal-backdrop"></div>
          <div class="modal-content">
            <div class="modal-header">
              <h2>Citar esta norma</h2>
              <button type="button" class="modal-close" aria-label="Cerrar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                </svg>
              </button>
            </div>
            <div class="modal-body">
              <div class="citation-format">
                <label>Formato Legal Peruano</label>
                <div class="citation-box">
                  <code id="cite-legal"></code>
                  <button type="button" class="btn-copy-cite" data-target="cite-legal">Copiar</button>
                </div>
              </div>
              <div class="citation-format">
                <label>APA 7</label>
                <div class="citation-box">
                  <code id="cite-apa"></code>
                  <button type="button" class="btn-copy-cite" data-target="cite-apa">Copiar</button>
                </div>
              </div>
              <div class="citation-format">
                <label>URL permanente</label>
                <div class="citation-box">
                  <code id="cite-url"></code>
                  <button type="button" class="btn-copy-cite" data-target="cite-url">Copiar</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <section class="version-history">
        <button id="history-toggle" class="history-toggle-btn" aria-expanded="false" aria-controls="history-content">
          <svg class="history-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>Historial de versiones</span>
          <span id="history-count" class="history-count-badge"></span>
          <svg class="chevron" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <div id="history-content" class="history-content" hidden aria-hidden="true">
          <div id="history-list"></div>
        </div>
      </section>

      {hasToc && (
        <nav class="toc" aria-label="Tabla de contenidos">
          <details open>
            <summary class="toc-toggle">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="15" y2="12"/>
                <line x1="3" y1="18" x2="18" y2="18"/>
              </svg>
              Tabla de contenidos
            </summary>
            <ol class="toc-list">
              {tocItems.map((item) => (
                <li class={`toc-item toc-level-${item.level}`}>
                  <a href={`#${item.slug}`}>{item.text}</a>
                </li>
              ))}
            </ol>
          </details>
        </nav>
      )}

      <article class="content-box prose" set:html={htmlContent} />
    </div>
  </main>
</Layout>

<script define:vars={{ identificador: id, citationData: JSON.stringify(citationData) }}>
  const citation = JSON.parse(citationData)

  const btnCite = document.getElementById('btn-cite')
  const citationModal = document.getElementById('citation-modal')

  // Citation Modal
  function formatDate(dateStr) {
    const [year, month, day] = dateStr.split('-')
    const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio',
      'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre']
    return `${Number.parseInt(day)} de ${months[Number.parseInt(month) - 1]} de ${year}`
  }

  function openCitationModal() {
    const pageUrl = window.location.href.split('#')[0]

    // Legal format: Ley N° 12345, publicada el 1 de enero de 2020 en el Diario Oficial El Peruano
    const legalCite = `${citation.rango} ${citation.identificador.toUpperCase().replace(/-/g, ' ')}, publicada el ${formatDate(citation.fechaPublicacion)} en el Diario Oficial ${citation.diarioOficial}.`

    // APA 7: Congreso de la Republica del Peru. (2020). Ley N° 12345, Titulo de la ley. El Peruano. URL
    const year = citation.fechaPublicacion.split('-')[0]
    const apaCite = `Congreso de la Republica del Peru. (${year}). ${citation.rango} ${citation.identificador.toUpperCase().replace(/-/g, ' ')}, ${citation.titulo}. ${citation.diarioOficial}. ${pageUrl}`

    document.getElementById('cite-legal').textContent = legalCite
    document.getElementById('cite-apa').textContent = apaCite
    document.getElementById('cite-url').textContent = pageUrl

    citationModal.hidden = false
    document.body.style.overflow = 'hidden'
  }

  function closeCitationModal() {
    citationModal.hidden = true
    document.body.style.overflow = ''
  }

  btnCite?.addEventListener('click', openCitationModal)
  citationModal?.querySelector('.modal-backdrop')?.addEventListener('click', closeCitationModal)
  citationModal?.querySelector('.modal-close')?.addEventListener('click', closeCitationModal)

  // Copy citation buttons
  document.querySelectorAll('.btn-copy-cite').forEach(btn => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.target
      const text = document.getElementById(targetId)?.textContent || ''
      try {
        await navigator.clipboard.writeText(text)
        btn.textContent = 'Copiado!'
        setTimeout(() => { btn.textContent = 'Copiar' }, 2000)
      } catch {
        btn.textContent = 'Error'
        setTimeout(() => { btn.textContent = 'Copiar' }, 2000)
      }
    })
  })

  // Heading link copy
  document.querySelectorAll('.heading-link').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault()
      const slug = btn.dataset.slug
      const url = `${window.location.href.split('#')[0]}#${slug}`
      try {
        await navigator.clipboard.writeText(url)
        btn.classList.add('copied')
        setTimeout(() => { btn.classList.remove('copied') }, 2000)
      } catch {}
    })
  })

  // Close modal on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !citationModal?.hidden) {
      closeCitationModal()
    }
    if (e.key === 'Escape' && !shareMenu?.hidden) {
      shareMenu.hidden = true
    }
  })

  // Print / PDF
  const btnPrint = document.getElementById('btn-print')
  btnPrint?.addEventListener('click', () => {
    window.print()
  })

  // Share menu
  const btnShare = document.getElementById('btn-share')
  const shareMenu = document.getElementById('share-menu')

  btnShare?.addEventListener('click', (e) => {
    e.stopPropagation()
    const isHidden = shareMenu?.hidden
    if (shareMenu) {
      shareMenu.hidden = !isHidden
      // Position the menu below the button
      const rect = btnShare.getBoundingClientRect()
      shareMenu.style.top = `${rect.bottom + 8}px`
      shareMenu.style.right = `${window.innerWidth - rect.right}px`
    }
  })

  // Close share menu when clicking outside
  document.addEventListener('click', (e) => {
    if (shareMenu && !shareMenu.hidden && !shareMenu.contains(e.target) && e.target !== btnShare) {
      shareMenu.hidden = true
    }
  })

  // Share options
  document.querySelectorAll('.share-option').forEach(btn => {
    btn.addEventListener('click', async () => {
      const shareType = btn.dataset.share
      const url = window.location.href
      const title = citation.titulo

      switch (shareType) {
        case 'twitter':
          window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`, '_blank')
          break
        case 'linkedin':
          window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`, '_blank')
          break
        case 'whatsapp':
          window.open(`https://wa.me/?text=${encodeURIComponent(title + ' ' + url)}`, '_blank')
          break
        case 'copy':
          try {
            await navigator.clipboard.writeText(url)
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Copiado!'
            setTimeout(() => {
              btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copiar enlace'
            }, 2000)
          } catch {}
          break
      }
      shareMenu.hidden = true
    })
  })

  // Bookmark functionality
  const btnBookmark = document.getElementById('btn-bookmark')
  const bookmarkText = document.getElementById('bookmark-text')
  const iconOutline = btnBookmark?.querySelector('.icon-bookmark-outline')
  const iconFilled = btnBookmark?.querySelector('.icon-bookmark-filled')

  function getBookmarks() {
    try {
      return JSON.parse(localStorage.getItem('bookmarks') || '[]')
    } catch { return [] }
  }

  function saveBookmarks(bookmarks) {
    localStorage.setItem('bookmarks', JSON.stringify(bookmarks))
  }

  function isBookmarked() {
    return getBookmarks().some(b => b.id === identificador)
  }

  function updateBookmarkUI() {
    const bookmarked = isBookmarked()
    if (iconOutline) iconOutline.style.display = bookmarked ? 'none' : 'block'
    if (iconFilled) iconFilled.style.display = bookmarked ? 'block' : 'none'
    if (bookmarkText) bookmarkText.textContent = bookmarked ? 'Guardado' : 'Guardar'
    if (btnBookmark) btnBookmark.classList.toggle('bookmarked', bookmarked)
  }

  function toggleBookmark() {
    const bookmarks = getBookmarks()
    const existing = bookmarks.findIndex(b => b.id === identificador)
    if (existing >= 0) {
      bookmarks.splice(existing, 1)
    } else {
      bookmarks.unshift({
        id: identificador,
        titulo: citation.titulo,
        rango: citation.rango,
        fecha: citation.fechaPublicacion,
        savedAt: new Date().toISOString()
      })
    }
    saveBookmarks(bookmarks)
    updateBookmarkUI()
  }

  btnBookmark?.addEventListener('click', toggleBookmark)
  updateBookmarkUI()

  // Recently viewed tracking
  function trackRecentlyViewed() {
    try {
      const recent = JSON.parse(localStorage.getItem('recentlyViewed') || '[]')
      const existing = recent.findIndex(r => r.id === identificador)
      if (existing >= 0) recent.splice(existing, 1)
      recent.unshift({
        id: identificador,
        titulo: citation.titulo,
        rango: citation.rango,
        fecha: citation.fechaPublicacion,
        viewedAt: new Date().toISOString()
      })
      // Keep only last 20
      localStorage.setItem('recentlyViewed', JSON.stringify(recent.slice(0, 20)))
    } catch {}
  }
  trackRecentlyViewed()

  // Search term highlighting
  function highlightSearchTerms() {
    try {
      const params = new URLSearchParams(window.location.search)
      const query = params.get('q')
      if (!query || query.length < 2) return

      const terms = query.toLowerCase().split(/\s+/).filter(t => t.length >= 2)
      if (terms.length === 0) return

      const content = document.querySelector('.prose')
      if (!content) return

      // Walk through text nodes and highlight matches
      const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, null, false)
      const nodesToProcess = []
      let node
      while (node = walker.nextNode()) {
        if (node.textContent && node.parentNode?.nodeName !== 'SCRIPT') {
          nodesToProcess.push(node)
        }
      }

      for (const textNode of nodesToProcess) {
        const text = textNode.textContent
        const lower = text.toLowerCase()
        let hasMatch = false
        for (const term of terms) {
          if (lower.includes(term)) { hasMatch = true; break }
        }
        if (!hasMatch) continue

        // Create regex pattern for all terms
        const pattern = terms.map(t => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|')
        const regex = new RegExp(`(${pattern})`, 'gi')
        const parts = text.split(regex)
        if (parts.length === 1) continue

        const fragment = document.createDocumentFragment()
        for (const part of parts) {
          if (terms.some(t => part.toLowerCase() === t)) {
            const mark = document.createElement('mark')
            mark.className = 'search-highlight'
            mark.textContent = part
            fragment.appendChild(mark)
          } else {
            fragment.appendChild(document.createTextNode(part))
          }
        }
        textNode.parentNode?.replaceChild(fragment, textNode)
      }

      // Scroll to first highlight
      const firstHighlight = document.querySelector('.search-highlight')
      if (firstHighlight) {
        setTimeout(() => {
          firstHighlight.scrollIntoView({ behavior: 'smooth', block: 'center' })
        }, 100)
      }
    } catch {}
  }
  highlightSearchTerms()

  // Version History
  const toggleBtn = document.getElementById('history-toggle')
  const content = document.getElementById('history-content')
  const historyList = document.getElementById('history-list')
  const countSpan = document.getElementById('history-count')
  let loaded = false

  // Load history count on page load
  async function loadHistoryCount() {
    try {
      const res = await fetch(`/api/normas/${identificador}/history`)
      const { data } = await res.json()
      if (data && data.length > 0) {
        countSpan.textContent = data.length
        countSpan.classList.add('visible')
      }
    } catch {}
  }
  loadHistoryCount()

  toggleBtn?.addEventListener('click', async () => {
    const isHidden = content.hidden
    content.hidden = !isHidden
    content.setAttribute('aria-hidden', String(!isHidden))
    toggleBtn.setAttribute('aria-expanded', String(isHidden))
    toggleBtn.classList.toggle('expanded', isHidden)

    if (isHidden && !loaded) {
      historyList.innerHTML = '<p class="loading">Cargando historial...</p>'
      try {
        const res = await fetch(`/api/normas/${identificador}/history`)
        const { data } = await res.json()
        loaded = true

        if (!data || data.length === 0) {
          historyList.innerHTML = `
            <div class="empty-state">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <p>Esta norma aún no tiene historial de cambios registrados.</p>
              <span class="empty-hint">El historial se genera cuando se registran modificaciones oficiales.</span>
            </div>
          `
          return
        }

        const latestHash = data[0].hash
        historyList.innerHTML = data.map((commit, i) => {
          const dateStr = new Date(commit.authorDate).toLocaleDateString('es-PE', { year: 'numeric', month: 'short', day: 'numeric' })
          return `
          <div class="history-item">
            <div class="commit-info">
              <span class="commit-date">${dateStr}</span>
              <span class="commit-message">${commit.subject}</span>
            </div>
            <div class="commit-actions">
              <a href="/leyes/${identificador}/version/${commit.hash}" class="btn-small" aria-label="Ver version del ${dateStr}">Ver</a>
              ${i < data.length - 1 ? `
                <a href="/leyes/${identificador}/diff?from=${data[i+1].hash}&to=${commit.hash}" class="btn-small btn-outline" title="Comparar con version anterior">Comparar</a>
              ` : '<span class="btn-small btn-disabled" title="Version inicial">Inicial</span>'}
            </div>
          </div>
        `}).join('')

      } catch (err) {
        historyList.innerHTML = `
          <div class="error-state">
            <p>Error al cargar el historial</p>
            <button onclick="location.reload()" class="btn-small">Reintentar</button>
          </div>
        `
      }
    }
  })
</script>

